{
  "name": "md-dive",
  "version": "0.1.0",
  "description": "A CLI tool for hierarchical navigation of large Markdown files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "md-dive": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "markdown",
    "cli",
    "navigator",
    "ai",
    "context"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
