{
    "name": "markdive",
    "version": "0.4.0",
    "description": "A CLI tool for hierarchical navigation of large Markdown files",
    "author": "Lambda-deep (https://github.com/Lambda-deep)",
    "license": "MIT",
    "homepage": "https://github.com/Lambda-deep/markdive#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Lambda-deep/markdive.git"
    },
    "bugs": {
        "url": "https://github.com/Lambda-deep/markdive/issues"
    },
    "keywords": [
        "markdown",
        "cli",
        "navigator",
        "ai",
        "context"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "markdive": "dist/cli.js"
    },
    "files": [
        "dist/",
        "skills/",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ],
    "engines": {
        "node": ">=16.0.0"
    },
    "scripts": {
        "clean": "rimraf dist",
        "build": "npm run clean && tsc",
        "test": "jest",
        "lint": "tsc --noEmit && biome check .",
        "format": "biome format --write .",
        "prepare": "npm run build"
    },
    "dependencies": {
        "commander": "^12.1.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.9",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.2",
        "jest": "^29.7.0",
        "rimraf": "^6.1.3",
        "ts-jest": "^29.2.5",
        "typescript": "^5.7.2"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.ts"
        ],
        "transform": {
            "^.+\\.tsx?$": [
                "ts-jest",
                {
                    "tsconfig": "tests/tsconfig.json"
                }
            ]
        }
    }
}
