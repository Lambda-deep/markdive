{
    "name": "md-dive",
    "version": "0.1.0",
    "description": "A CLI tool for hierarchical navigation of large Markdown files",
    "author": "Lambda-deep (https://github.com/Lambda-deep)",
    "license": "MIT",
    "homepage": "https://github.com/Lambda-deep/md-dive#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Lambda-deep/md-dive.git"
    },
    "bugs": {
        "url": "https://github.com/Lambda-deep/md-dive/issues"
    },
    "keywords": [
        "markdown",
        "cli",
        "navigator",
        "ai",
        "context"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "md-dive": "dist/cli.js"
    },
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=16.0.0"
    },
    "scripts": {
        "build": "tsc",
        "test": "jest",
        "lint": "tsc --noEmit",
        "prepare": "npm run build"
    },
    "dependencies": {
        "commander": "^12.1.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.2",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.5",
        "typescript": "^5.7.2"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.ts"
        ]
    }
}
